# ==============================================================================
# 認証情報テンプレート
# このファイルを .env にコピーして、実際の値を設定してください
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Snowflake接続情報
# 取得方法: Snowflake WebUI にログイン → 左下のアカウント名をクリック
#           → 「Copy account identifier」を選択
#           → 「MYORG-MYACCOUNT」の形式でコピーされる
# ------------------------------------------------------------------------------

# 組織名（「MYORG-MYACCOUNT」の「MYORG」部分）
SNOWFLAKE_ORGANIZATION_NAME=your-organization-name

# アカウント名（「MYORG-MYACCOUNT」の「MYACCOUNT」部分）
SNOWFLAKE_ACCOUNT_NAME=your-account-name

# 管理者ユーザー名（ACCOUNTADMINロールを持つユーザー）
SNOWFLAKE_USER=your-admin-user

# 管理者パスワード
SNOWFLAKE_PASSWORD=your-password

# ------------------------------------------------------------------------------
# AWS接続情報
# 取得方法: AWS マネジメントコンソール → IAM → ユーザー → 対象ユーザー
#           → 「セキュリティ認証情報」タブ → 「アクセスキーを作成」
# ------------------------------------------------------------------------------

# IAMユーザーのアクセスキーID（例: AKIAIOSFODNN7EXAMPLE）
AWS_ACCESS_KEY_ID=your-access-key-id

# IAMユーザーのシークレットアクセスキー（例: wJalrXUtnFEMI/K7MDENG/...）
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# ------------------------------------------------------------------------------
# DuckDB学習用 IAM ユーザーのアクセスキー
# 取得方法: terraform apply 後、以下のコマンドで取得する
#   terraform -chdir=terraform show -json | python3 -c "
#   import json,sys
#   data=json.load(sys.stdin)
#   for r in data['values']['root_module']['child_modules']:
#       if 'duckdb' in r['address']:
#           for res in r['resources']:
#               if 'access_key' in res['address']:
#                   v=res['values']
#                   print('DUCKDB_AWS_ACCESS_KEY_ID=' + v['id'])
#                   print('DUCKDB_AWS_SECRET_ACCESS_KEY=' + v['secret'])
#   "
# ⚠️ シークレットはこのコマンドでのみ取得可能。再表示はできないので必ず控えること。
# ------------------------------------------------------------------------------
DUCKDB_AWS_ACCESS_KEY_ID=your-duckdb-access-key-id
DUCKDB_AWS_SECRET_ACCESS_KEY=your-duckdb-secret-access-key
DUCKDB_S3_BUCKET=duckdb-study-sandbox
DUCKDB_S3_REGION=ap-northeast-1

# ------------------------------------------------------------------------------
# 環境設定
# 作成するリソース名のプレフィックスに使用（変更不要）
# ------------------------------------------------------------------------------
ENVIRONMENT=sandbox
